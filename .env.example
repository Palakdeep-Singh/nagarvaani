# NagarVaani — Environment Variables
# Copy to .env and fill in your values

# WhatsApp Cloud API (Meta Business)
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_phone_id_here
WHATSAPP_VERIFY_TOKEN=nagarvaani_2026

# Supabase (PostgreSQL + pgvector)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Upstash Redis
UPSTASH_REDIS_URL=rediss://your-upstash-url

# Security
HASH_SALT=your_random_salt_string_here

# SQLite (demo only — remove for production)
DB_PATH=nagarvaani.db
